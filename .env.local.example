# ─── AI Provider Configuration ───────────────────────────────────────────────
# Which AI provider to use: anthropic | openai | ollama | mock
# When absent, the app auto-detects from available API keys, defaulting to mock.
AI_PROVIDER=anthropic

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Ollama (local) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
